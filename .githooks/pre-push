#!/usr/bin/env bash

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

current_branch="$(git branch --show-current)"
upstream_ref=""

if upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null)"; then
  :
elif [[ "$current_branch" == "staging" ]] && git show-ref --verify --quiet refs/remotes/origin/staging; then
  upstream_ref="origin/staging"
elif git show-ref --verify --quiet refs/remotes/origin/main; then
  upstream_ref="origin/main"
else
  echo "pre-push: unable to determine a comparison base; skipping scoped checks."
  exit 0
fi

changed_files=()
while IFS= read -r path; do
  [[ -n "$path" ]] || continue
  changed_files+=("$path")
done < <(git diff --name-only --diff-filter=ACMR "$upstream_ref"...HEAD)

if [[ ${#changed_files[@]} -eq 0 ]]; then
  echo "pre-push: no repo file changes detected against $upstream_ref; skipping scoped checks."
  exit 0
fi

echo "pre-push: running relevant checks for changes against $upstream_ref"
printf '  %s\n' "${changed_files[@]}"
"$repo_root/scripts/relevant-checks.sh" "${changed_files[@]}"
