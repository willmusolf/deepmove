{
  "name": "deepmove-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/copy-stockfish-assets.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "postinstall": "patch-package && node scripts/copy-stockfish-assets.mjs"
  },
  "dependencies": {
    "chess.js": "^1.3.0",
    "chessground": "^9.1.1",
    "idb": "^8.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.0.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "@vitejs/plugin-react": "4.3.4",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "jsdom": "24.1.3",
    "patch-package": "^8.0.1",
    "stockfish": "18.0.5",
    "typescript": "5.6.3",
    "vite": "6.0.3",
    "vitest": "4.1.5"
  }
}
