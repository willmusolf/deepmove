{
  "name": "deepmove-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/copy-stockfish-assets.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "doctor": "node scripts/verify-install.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "postinstall": "patch-package && node scripts/copy-stockfish-assets.mjs && node scripts/verify-install.mjs"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.17",
    "@rolldown/binding-darwin-x64": "1.0.0-rc.17"
  },
  "dependencies": {
    "@sentry/react": "^10.52.0",
    "chess.js": "^1.3.0",
    "chessground": "^9.1.1",
    "idb": "^8.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "jsdom": "29.1.1",
    "patch-package": "^8.0.1",
    "stockfish": "18.0.7",
    "typescript": "6.0.3",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  }
}
