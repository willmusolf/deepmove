# Copy this to .env.local (frontend) and fill in real values.
# NEVER commit .env.local — it's in .gitignore.
# Vite exposes VITE_* variables to the browser — never put secrets here.

# Backend API URL
VITE_API_URL=http://localhost:8000

# Sentry (error observability — leave empty to disable)
# Get from: sentry.io → your project → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=
