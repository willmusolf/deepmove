# Copy this to .env.local (frontend) and fill in real values.
# NEVER commit .env.local — it's in .gitignore.
# Vite exposes VITE_* variables to the browser — never put secrets here.

# Backend API URL
VITE_API_URL=http://localhost:8000

# Optional frontend observability
VITE_SENTRY_DSN=
VITE_COMMIT_SHA=

# Feature flags
VITE_COACHING_ENABLED=false

# Optional AdSense config
VITE_ADSENSE_ENABLED=false
VITE_ADSENSE_DESKTOP_RAIL_SLOT=
VITE_ADSENSE_MOBILE_BANNER_SLOT=
