# Copy this file to `.env` for local backend development.
# Never commit real credentials.

# Core app config
ENVIRONMENT=development
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql://user:password@localhost:5432/deepmove
FRONTEND_URL=http://localhost:5173

# AI coaching
ANTHROPIC_API_KEY=replace-with-your-anthropic-key
COACHING_ENABLED=false
FREE_TIER_DAILY_LESSONS=50
PREMIUM_DAILY_LESSONS=500
GUEST_DAILY_LESSONS=10
MAX_DAILY_LLM_CALLS=5000
ESTIMATED_LLM_COST_USD=0.0015

# OAuth - Lichess
LICHESS_CLIENT_ID=
LICHESS_CLIENT_SECRET=
LICHESS_REDIRECT_URI=http://localhost:8000/auth/lichess/callback

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# OAuth - Chess.com
CHESSCOM_CLIENT_ID=
CHESSCOM_CLIENT_SECRET=
CHESSCOM_REDIRECT_URI=http://localhost:8000/auth/chesscom/callback

# Email / password reset
RESEND_API_KEY=
PASSWORD_RESET_EXPIRE_MINUTES=30
PASSWORD_RESET_FROM_EMAIL=noreply@deepmove.io

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Optional production/staging CORS overrides
ALLOWED_ORIGINS_CSV=
ALLOWED_ORIGIN_REGEX=

# Optional deployment metadata
GIT_COMMIT_SHA=local-dev
BUILD_TIME=2026-01-01T00:00:00Z
