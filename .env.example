# Copy this to .env (backend) and fill in real values.
# NEVER commit .env — it's in .gitignore.

# ── Anthropic ──────────────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Database (Neon) ────────────────────────────────────────────────────────
# Get from: neon.tech → your project → Connection Details → Connection string
# Use the pooled endpoint (port 5432) with ?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require

# ── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=generate-a-long-random-string-here
FRONTEND_URL=http://localhost:5173
TRUSTED_PROXY_DEPTH=1

# ── OAuth — Lichess ────────────────────────────────────────────────────────
LICHESS_CLIENT_ID=your-lichess-client-id
LICHESS_REDIRECT_URI=http://localhost:8000/auth/lichess/callback

# ── OAuth — Google ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Coaching / quotas ──────────────────────────────────────────────────────
COACHING_ENABLED=false
FREE_TIER_DAILY_LESSONS=50
PREMIUM_DAILY_LESSONS=500
GUEST_DAILY_LESSONS=10
MAX_DAILY_LLM_CALLS=5000
ESTIMATED_LLM_COST_USD=0.0015

# ── Resend (transactional email — password reset) ──────────────────────────
# Get from: resend.com → API Keys
# Leave empty in development; reset URLs are logged to console instead.
RESEND_API_KEY=
PASSWORD_RESET_FROM_EMAIL=noreply@deepmove.io

# ── CORS ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOWED_ORIGIN_REGEX=

# ── Sentry ─────────────────────────────────────────────────────────────────
# Get from: sentry.io → your project → Settings → Client Keys (DSN)
SENTRY_DSN=

# ── Stripe ─────────────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Get from: dashboard.stripe.com → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Get from: dashboard.stripe.com → Products → your $5/mo price → Price ID
STRIPE_PRICE_ID=price_...

# ── OpenAI (slideshow generator only) ─────────────────────────────────────
# Get from: platform.openai.com → API Keys
# Only needed to run scripts/slideshow_generator.py (DALL-E 3 image generation)
OPENAI_API_KEY=your-openai-api-key-here
